{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build using the default CMake generator.",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build using the default CMake generator.",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "release-no-tests",
      "displayName": "Release without tests",
      "description": "Release application build without Catch2 test targets.",
      "binaryDir": "${sourceDir}/build/release-no-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TET_RAY_GAME_BUILD_APP": "ON",
        "TET_RAY_GAME_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "debug-sanitize",
      "displayName": "Debug Sanitizers",
      "description": "Debug build with address and undefined behavior sanitizers where supported.",
      "binaryDir": "${sourceDir}/build/debug-sanitize",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TET_RAY_GAME_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "debug-clang-tidy",
      "displayName": "Debug clang-tidy",
      "description": "Debug build with optional clang-tidy integration if clang-tidy is installed.",
      "binaryDir": "${sourceDir}/build/debug-clang-tidy",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TET_RAY_GAME_ENABLE_CLANG_TIDY": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "release"
    },
    {
      "name": "release-no-tests",
      "displayName": "Release without tests",
      "configurePreset": "release-no-tests"
    },
    {
      "name": "debug-sanitize",
      "displayName": "Debug Sanitizers",
      "configurePreset": "debug-sanitize"
    },
    {
      "name": "debug-clang-tidy",
      "displayName": "Debug clang-tidy",
      "configurePreset": "debug-clang-tidy"
    }
  ]
}
